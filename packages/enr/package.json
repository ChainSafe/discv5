{
  "name": "@chainsafe/enr",
  "version": "6.0.1",
  "description": "Ethereum name record",
  "type": "module",
  "files": [
    "src",
    "lib"
  ],
  "exports": {
    ".": {
      "import": "./lib/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "*",
        "lib/*",
        "lib/*/index"
      ]
    }
  },
  "types": "./lib/index.d.ts",
  "scripts": {
    "check-types": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm build",
    "lint": "biome check src test",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:perf": "NODE_OPTIONS='--max-old-space-size=4096 --loader=ts-node/esm' benchmark 'bench/**/*.bench.ts'",
    "test:unit": "vitest --run 'test/unit'"
  },
  "pre-push": [
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ChainSafe/discv5.git"
  },
  "keywords": [
    "discovery",
    "discv5",
    "ethereum",
    "p2p"
  ],
  "author": "ChainSafe Systems",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/ChainSafe/discv5/issues"
  },
  "homepage": "https://github.com/ChainSafe/discv5#readme",
  "dependencies": {
    "@ethereumjs/rlp": "^10.1.1",
    "@libp2p/crypto": "^5.0.1",
    "@libp2p/interface": "^3.1.0",
    "@libp2p/peer-id": "^6.0.4",
    "@multiformats/multiaddr": "^13.0.1",
    "@scure/base": "^2.0.0",
    "ethereum-cryptography": "^3.2.0"
  }
}
